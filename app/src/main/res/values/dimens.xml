<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        My device: Xiaomi Mi A1
        My android version: 9

        Use the Landscape mode
        In Landscape mode, the values X and Y are inverted

        Portrait:
        Device Width: X => 1080
        Device Height: Y => 1920

        Landscape:
        Device Width: X => 1920
        Device Height: Y => 1080

        Find the dimensions of your device in MainActivity ( DEBUG )

        Add the android:background="@color/colorAlphaWhite" in layout ( RelativeLayout ) to help the adjusts
    -->

    <!--
        Scaled for Samsung Galaxy S25+ at FHD+ screen resolution setting
        Landscape: 2340 x 1080 (width scaled from 1920->2340, height unchanged at 1080)
        If your phone is set to WQHD+ (3120 x 1440), these will be off and need re-scaling/recalibration.
    -->

    <!-- Board -->
    <dimen name="boardWidth" tools:ignore="PxUsage">1974px</dimen>
    <dimen name="boardHeight" tools:ignore="PxUsage">897px</dimen>
    <dimen name="boardMarginBottom" tools:ignore="PxUsage">0.0099px</dimen>

    <!-- Canvas -->
    <dimen name="canvasWidth" tools:ignore="PxUsage">1776px</dimen>
    <dimen name="canvasHeight" tools:ignore="PxUsage">731px</dimen>
    <dimen name="canvasMarginTop" tools:ignore="PxUsage">82px</dimen>

    <!-- Buttons -->
    <dimen name="buttonWidth" tools:ignore="PxUsage">341px</dimen>
    <dimen name="buttonHeight" tools:ignore="PxUsage">75px</dimen>
    <dimen name="buttonNormalMarginStart" tools:ignore="PxUsage">213px</dimen>
    <dimen name="buttonCloseMarginEnd" tools:ignore="PxUsage">207px</dimen>
    <dimen name="buttonTrickshotSecondLineMarginEnd" tools:ignore="PxUsage">207px</dimen>
</resources>
